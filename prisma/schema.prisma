generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  CREATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum SubscriptionPlan {
  FREE
  PROFESSIONAL
  UNLIMITED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum AdStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum GigStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  CLOSED
}

enum ProjectStatus {
  PENDING_AGREEMENT
  ACTIVE
  DELIVERED
  REVISION
  COMPLETED
  DISPUTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  ESCROW_HELD
  RELEASED
  REFUNDED
  FAILED
}

enum PaymentType {
  SUBSCRIPTION
  ESCROW
  WITHDRAWAL
  COMMISSION
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum NotificationType {
  MESSAGE
  GIG_POSTED
  PROPOSAL_RECEIVED
  PROJECT_ACCEPTED
  PAYMENT_RECEIVED
  REVIEW_ADDED
  SUBSCRIPTION_EXPIRY
  WITHDRAWAL_APPROVED
  SYSTEM
}

enum PortfolioLinkType {
  YOUTUBE
  SPOTIFY
  SOUNDCLOUD
  AUDIOMACK
  APPLE_MUSIC
  INSTAGRAM
  TIKTOK
  WEBSITE
  OTHER
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  LINK
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  image         String?
  role          UserRole   @default(CLIENT)
  status        UserStatus @default(ACTIVE)
  emailVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  subscription  Subscription?
  creatorCategories CreatorCategory[]
  ads           Ad[]
  portfolioLinks PortfolioLink[]
  gigs          Gig[]          @relation("ClientGigs")
  gigApplications GigApplication[]
  projectsAsClient Project[] @relation("ClientProjects")
  projectsAsCreator Project[] @relation("CreatorProjects")
  sentMessages  Message[]      @relation("SentMessages")
  chatParticipants ChatParticipant[]
  payments      Payment[]
  withdrawals   Withdrawal[]
  reviewsGiven  Review[]       @relation("ReviewsGiven")
  reviewsReceived Review[]     @relation("ReviewsReceived")
  notifications Notification[]
  savedCreators SavedCreator[] @relation("SavedBy")
  savedBy       SavedCreator[] @relation("SavedCreator")
  adminLogs     AdminLog[]
  featuredAds   FeaturedAd[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?  @db.Text
  skills          String[] @default([])
  yearsExperience Int      @default(0)
  languages       String[] @default([])
  country         String?
  city            String?
  isVerified      Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  website         String?
  instagram       String?
  tiktok          String?
  twitter         String?
  youtube         String?
  spotify         String?
  soundcloud      String?
  totalProjects   Int      @default(0)
  repeatClients   Int      @default(0)
  averageRating   Float    @default(0)
  totalReviews    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([country, city])
  @@index([averageRating])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String             @unique
  plan      SubscriptionPlan   @default(FREE)
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime?
  autoRenew Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([plan, status])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  creatorCategories CreatorCategory[]
  ads               Ad[]
  gigs              Gig[]

  @@index([slug])
}

model CreatorCategory {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
}

model Ad {
  id            String   @id @default(cuid())
  userId        String
  categoryId    String
  title         String
  description   String   @db.Text
  priceMin      Float
  priceMax      Float
  deliveryDays  Int
  revisionCount Int      @default(1)
  requirements  String?  @db.Text
  terms         String?  @db.Text
  featuredImage String?
  status        AdStatus @default(DRAFT)
  isFeatured    Boolean  @default(false)
  viewCount     Int      @default(0)
  hireCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category       @relation(fields: [categoryId], references: [id])
  portfolioLinks PortfolioLink[]
  featuredAds  FeaturedAd[]
  projects     Project[]

  @@index([status, createdAt])
  @@index([userId])
  @@index([categoryId])
}

model PortfolioLink {
  id        String            @id @default(cuid())
  userId    String
  adId      String?
  url       String
  type      PortfolioLinkType
  title     String?
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  ad   Ad?   @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Gig {
  id                 String    @id @default(cuid())
  clientId           String
  categoryId         String
  title              String
  description        String    @db.Text
  budget             Float
  deadline           DateTime?
  genre              String?
  location           String?
  isRemote           Boolean   @default(true)
  requiredExperience Int       @default(0)
  attachments        String[]  @default([])
  referenceLinks     String[]  @default([])
  status             GigStatus @default(OPEN)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client       User             @relation("ClientGigs", fields: [clientId], references: [id], onDelete: Cascade)
  category     Category         @relation(fields: [categoryId], references: [id])
  applications GigApplication[]
  projects     Project[]

  @@index([status, createdAt])
  @@index([clientId])
}

model GigApplication {
  id         String   @id @default(cuid())
  gigId      String
  creatorId  String
  proposal   String   @db.Text
  price      Float
  deliveryDays Int
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())

  gig     Gig  @relation(fields: [gigId], references: [id], onDelete: Cascade)
  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([gigId, creatorId])
}

model Project {
  id          String        @id @default(cuid())
  clientId    String
  creatorId   String
  adId        String?
  gigId       String?
  title       String
  description String?       @db.Text
  price       Float
  deliveryDate DateTime?
  status      ProjectStatus @default(PENDING_AGREEMENT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client   User             @relation("ClientProjects", fields: [clientId], references: [id])
  creator  User             @relation("CreatorProjects", fields: [creatorId], references: [id])
  ad       Ad?              @relation(fields: [adId], references: [id])
  gig      Gig?             @relation(fields: [gigId], references: [id])
  contract ProjectContract?
  deliveries Delivery[]
  payments Payment[]
  reviews  Review[]
  chats    Chat[]

  @@index([clientId])
  @@index([creatorId])
  @@index([status])
}

model ProjectContract {
  id              String   @id @default(cuid())
  projectId       String   @unique
  scope           String   @db.Text
  price           Float
  deliveryDate    DateTime
  revisionCount   Int
  deliverables    String   @db.Text
  rights          String   @db.Text
  terms           String   @db.Text
  paymentMethod   String   @default("PLATFORM")
  supportPolicy   String   @db.Text
  clientAccepted  Boolean  @default(false)
  creatorAccepted Boolean  @default(false)
  clientAcceptedAt DateTime?
  creatorAcceptedAt DateTime?
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Delivery {
  id          String   @id @default(cuid())
  projectId   String
  links       String[]
  message     String?  @db.Text
  isAccepted  Boolean  @default(false)
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String   @id @default(cuid())
  projectId String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project      Project?          @relation(fields: [projectId], references: [id])
  participants ChatParticipant[]
  messages     Message[]

  @@index([updatedAt])
}

model ChatParticipant {
  id       String @id @default(cuid())
  chatId   String
  userId   String
  lastRead DateTime?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  senderId  String
  content   String      @db.Text
  type      MessageType @default(TEXT)
  metadata  Json?
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation("SentMessages", fields: [senderId], references: [id])

  @@index([chatId, createdAt])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  projectId       String?
  subscriptionId  String?
  type            PaymentType
  amount          Float
  commission      Float         @default(0)
  netAmount       Float
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  pandoraRef      String?
  pandoraResponse Json?
  invoiceUrl      String?
  receiptUrl      String?
  adminApproved   Boolean       @default(false)
  adminApprovedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  project      Project?      @relation(fields: [projectId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  escrow       Escrow?

  @@index([userId])
  @@index([status])
}

model Escrow {
  id          String   @id @default(cuid())
  paymentId   String   @unique
  amount      Float
  isReleased  Boolean  @default(false)
  releasedAt  DateTime?
  releasedBy  String?
  createdAt   DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Withdrawal {
  id          String           @id @default(cuid())
  userId      String
  amount      Float
  status      WithdrawalStatus @default(PENDING)
  method      String?
  accountInfo Json?
  adminNote   String?
  processedAt DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model Review {
  id         String   @id @default(cuid())
  projectId  String
  reviewerId String
  revieweeId String
  rating     Int
  comment    String   @db.Text
  response   String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project  Project @relation(fields: [projectId], references: [id])
  reviewer User    @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User    @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@unique([projectId, reviewerId])
  @@index([revieweeId])
}

model SavedCreator {
  id        String   @id @default(cuid())
  clientId  String
  creatorId String
  createdAt DateTime @default(now())

  client  User @relation("SavedBy", fields: [clientId], references: [id], onDelete: Cascade)
  creator User @relation("SavedCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([clientId, creatorId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model FeaturedAd {
  id        String   @id @default(cuid())
  adId      String
  userId    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  ad   Ad   @relation(fields: [adId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([isActive, sortOrder])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   Json?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text
  coverImage  String?
  isPublished Boolean  @default(false)
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String   @db.Text
  avatar    String?
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model SuccessStory {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  image       String?
  clientName  String?
  creatorName String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model LandingStat {
  id        String   @id @default(cuid())
  label     String
  value     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
